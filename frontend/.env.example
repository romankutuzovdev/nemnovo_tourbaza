# Прод / один origin: пусто — в браузере запросы на /api (прокси Next → Django).
# Отдельный хост или туннель: полный URL бэкенда.
# NEXT_PUBLIC_API_URL=

# Rewrites в next.config.js и SSR в lib/api.ts. На VPS с nginx на :8005:
# BACKEND_URL=http://127.0.0.1:8005
# Локально без nginx-обёртки:
# BACKEND_URL=http://127.0.0.1:8000
